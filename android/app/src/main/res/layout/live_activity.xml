<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingLeft="0dp"
    android:paddingRight="16dp"
    android:paddingBottom="12dp"
    android:paddingTop="4dp">

    <!-- Header: Line name & direction -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        
        <TextView
            android:id="@+id/tv_line_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BTS สุขุมวิท"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />
            
        <TextView
            android:id="@+id/tv_direction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="มุ่งหน้า เคหะฯ"
            android:textColor="#94A3B8"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/pb_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:progress="2"
        android:max="10"
        android:progressTint="#7DC242"
        android:progressBackgroundTint="#334155"
        android:layout_marginBottom="8dp" />

    <!-- Stations names -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">
        
        <TextView
            android:id="@+id/tv_current_station"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="อโศก"
            android:textColor="#E2E8F0"
            android:textSize="14sp" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" ➔ "
            android:textColor="#64748B"
            android:textSize="14sp" />
            
        <TextView
            android:id="@+id/tv_next_station"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="พร้อมพงษ์"
            android:textColor="#F8FAFC"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="right" />
    </LinearLayout>

    <!-- Divider line (Using ImageView as it is fully supported by RemoteViews, whereas generic View is not) -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#334155"
        android:layout_marginBottom="12dp"
        android:contentDescription="divider" />

    <!-- Info row & action buttons -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">
        
        <!-- Info: Walk / ETA / Speed -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2">
            
            <TextView
                android:id="@+id/tv_walk_meters"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚶 เดินอีก 80 ม."
                android:textColor="#38BDF8"
                android:textSize="12sp"
                android:layout_marginBottom="2dp" />
                
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                
                <TextView
                    android:id="@+id/tv_eta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱ อีก 14 นาที"
                    android:textColor="#34D399"
                    android:textSize="12sp"
                    android:layout_marginRight="8dp" />
                    
                <TextView
                    android:id="@+id/tv_speed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💨 5.2 กม./ชม"
                    android:textColor="#FB923C"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Actions (Removing custom style dependencies for clean rendering on all vendor ROMs) -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.8"
            android:gravity="right">
            
            <TextView
                android:id="@+id/btn_next"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ถัดไป"
                android:textColor="#38BDF8"
                android:textSize="14sp"
                android:textStyle="bold"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_stop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="จบ"
                android:textColor="#EF4444"
                android:textSize="14sp"
                android:textStyle="bold"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
